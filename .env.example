# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real tokens.

# ---- Harness ----
HARNESS_ACCOUNT_ID=
HARNESS_API_KEY=
HARNESS_ORG=default
HARNESS_PROJECT=custom_plugins
CREATE_PROJECT=true

# ---- GitHub ----
GITHUB_USERNAME=
GITHUB_REPO=cd-tidbit-custom-plugins
# Used as a Harness secret AND for the cluster imagePullSecret.
GITHUB_PAT=

# ---- Delegate ----
# Delegate selector the K8s connector targets. Must match a tag on your installed
# delegate. The script tags the delegate it installs with this value.
DELEGATE_SELECTOR=helm-delegate

# Display name for the delegate the script installs via Helm.
DELEGATE_NAME=custom-plugins-delegate

# ---- Kanboard (ITSM target the plugin updates) ----
# In-cluster URL the plugin step uses to reach Kanboard. The default points at
# the Service the Kanboard Helm chart creates in the kanboard namespace.
KANBOARD_URL=http://kanboard.kanboard.svc.cluster.local:8080/jsonrpc.php
# Kanboard API token. setup.sh generates one (openssl rand -hex 16) if blank
# and writes it here. Injected into the Kanboard pod as API_AUTHENTICATION_TOKEN
# and into the Plugin step as KANBOARD_API_TOKEN — the plugin authenticates as
# the reserved `jsonrpc` user with this value.
KANBOARD_API_TOKEN=
# Project + column + task IDs. setup.sh creates the "Deployments" project, four
# columns (Backlog/Dev/QA/Prod), and one demo task. Leave values blank to have
# setup.sh create them and write the IDs here. 
KANBOARD_PROJECT_ID=1
KANBOARD_TASK_ID=1
KANBOARD_COL_BACKLOG=1
KANBOARD_COL_DEV=2
KANBOARD_COL_QA=3
KANBOARD_COL_PROD=4
